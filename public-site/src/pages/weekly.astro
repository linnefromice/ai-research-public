---
import BaseLayout from '../layouts/BaseLayout.astro';
import { dailyFeatures } from '../features';
import { getCollection } from 'astro:content';
import { getUnpublishedIds, toD1Id } from '../lib/d1-client';
import { dedupByLang } from '../lib/multilingual';

// ビルド時に過去 7 日分のレポートを feature 別に集計して静的生成
const unpublished = await getUnpublishedIds();
const cutoff = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);

interface FeatureSummary {
  feature: string;
  label: string;
  color: string;
  reports: { date: string; slug: string; title: string }[];
}

const summaries: FeatureSummary[] = [];
for (const f of dailyFeatures) {
  try {
    const reports = await getCollection(f.slug as any);
    const deduped = dedupByLang(reports);
    const recent = (deduped as any[])
      .filter(r => !unpublished.has(toD1Id(f.slug, r.id)))
      .filter(r => {
        const dateMatch = (r.id || '').match(/^(\d{4}-\d{2}-\d{2})/);
        return dateMatch && dateMatch[1] >= cutoff;
      })
      .map(r => ({
        date: (r.id.match(/^(\d{4}-\d{2}-\d{2})/) ?? ['', ''])[1],
        slug: r.id,
        title: r.data?.title ?? `${f.label} ${r.id}`,
      }))
      .sort((a: any, b: any) => b.date.localeCompare(a.date));
    if (recent.length > 0) {
      summaries.push({ feature: f.slug, label: f.label, color: f.color, reports: recent });
    }
  } catch { /* skip */ }
}
---

<BaseLayout title="Weekly Digest" activeFeature="_weekly">
  <h1>📅 Weekly Digest</h1>
  <p style="color: var(--color-text-muted); margin-bottom: 1.5rem;">
    Past 7 days reports across all features
  </p>

  {summaries.length === 0 ? (
    <p style="color: var(--color-text-muted);">No reports in the last 7 days.</p>
  ) : (
    <div style="display: grid; gap: 1rem;">
      {summaries.map(s => (
        <details style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 8px; padding: 0.75rem 1rem;">
          <summary style="cursor: pointer; font-weight: 600; display: flex; align-items: center; gap: 0.5rem;">
            <span style={`width: 10px; height: 10px; border-radius: 50%; background: ${s.color}; flex-shrink: 0;`}></span>
            {s.label} <span style="color: var(--color-text-muted); font-weight: normal;">({s.reports.length})</span>
          </summary>
          <ul style="margin: 0.75rem 0 0 0; padding-left: 1rem; list-style: none;">
            {s.reports.map(r => (
              <li style="padding: 0.25rem 0;">
                <a href={`/${s.feature}/${r.slug}/`} style="color: var(--color-primary);">{r.date}</a>
                <span style="color: var(--color-text-muted); font-size: 0.85rem; margin-left: 0.5rem;">{r.title}</span>
              </li>
            ))}
          </ul>
        </details>
      ))}
    </div>
  )}
</BaseLayout>
