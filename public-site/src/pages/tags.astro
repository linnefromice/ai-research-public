---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getFeatureColor } from '../features';
import { getReportMeta, getAllReportTags } from '../lib/d1-client';

// ビルド時に D1 から全データ取得（API Key はサーバーサイドのみ）
const reportMeta = await getReportMeta();
const reportTags = await getAllReportTags();

interface TagCount {
  tag: string;
  tag_type: string;
  report_count: number;
}

// タグ集計（SSG）
const tagCounts = new Map<string, { tag_type: string; count: number }>();
for (const [, tags] of reportTags) {
  for (const t of tags) {
    const existing = tagCounts.get(t.tag);
    if (existing) {
      existing.count++;
    } else {
      tagCounts.set(t.tag, { tag_type: t.tag_type, count: 1 });
    }
  }
}

const themes: TagCount[] = [...tagCounts.entries()]
  .filter(([, v]) => v.tag_type === 'theme')
  .map(([tag, v]) => ({ tag, tag_type: 'theme', report_count: v.count }))
  .sort((a, b) => b.report_count - a.report_count)
  .slice(0, 50);

const keywords: TagCount[] = [...tagCounts.entries()]
  .filter(([, v]) => v.tag_type === 'keyword')
  .map(([tag, v]) => ({ tag, tag_type: 'keyword', report_count: v.count }))
  .sort((a, b) => b.report_count - a.report_count)
  .slice(0, 100);

const maxCount = Math.max(...keywords.map(k => k.report_count), 1);
function getFontSize(count: number): string {
  const min = 0.75;
  const max = 2.0;
  const size = min + (count / maxCount) * (max - min);
  return `${size.toFixed(2)}rem`;
}

// フィルタ用データを SSG で埋め込む（API Key 不要）
interface ReportEntry {
  id: string;
  feature: string;
  date: string;
  title: string;
  tags: string[];
  color: string;
}
const filterData: ReportEntry[] = [...reportMeta.entries()].map(([id, meta]) => {
  const feature = id.split('/')[0];
  const tags = (reportTags.get(id) ?? []).map(t => t.tag);
  return {
    id,
    feature,
    date: meta.date,
    title: meta.id ? (meta as any).title ?? `${feature} Report` : `${feature} Report`,
    tags,
    color: getFeatureColor(feature),
  };
});
---

<BaseLayout title="Tags" activeFeature="_tags">
  <div class="tags-page">
    <h1>Tags</h1>

    {themes.length > 0 && (
      <section class="tag-section">
        <h2>Themes</h2>
        <div class="tag-list">
          {themes.map((t) => (
            <button class="tag-item theme clickable-tag" data-tag={t.tag} title={`${t.report_count} reports`}>
              {t.tag} <span class="count">{t.report_count}</span>
            </button>
          ))}
        </div>
      </section>
    )}

    {keywords.length > 0 && (
      <section class="tag-section">
        <h2>Keywords</h2>
        <div class="tag-cloud">
          {keywords.map((k) => (
            <button
              class="cloud-item clickable-tag"
              style={`font-size: ${getFontSize(k.report_count)}`}
              data-tag={k.tag}
              title={`${k.report_count} reports`}
            >
              {k.tag}
            </button>
          ))}
        </div>
      </section>
    )}

    {themes.length === 0 && keywords.length === 0 && (
      <p class="empty">No tags found. Tags will appear after report generation.</p>
    )}

    <section class="filter-results hidden" id="filter-results">
      <div class="filter-header">
        <h2 id="filter-title">Reports</h2>
        <button class="clear-filter" id="clear-filter">Clear</button>
      </div>
      <div class="filter-list" id="filter-list"></div>
    </section>
  </div>
</BaseLayout>

<script type="application/json" id="filter-data" set:html={JSON.stringify(filterData)} />

<script>
  const filterResults = document.getElementById('filter-results');
  const filterTitle = document.getElementById('filter-title');
  const filterList = document.getElementById('filter-list');
  const clearBtn = document.getElementById('clear-filter');
  let activeTag = null;

  // SSG で埋め込んだデータを使用（API fetch 不要）
  const allReports = JSON.parse(document.getElementById('filter-data')?.textContent || '[]');

  function filterByTag(tag) {
    activeTag = tag;

    document.querySelectorAll('.clickable-tag').forEach(el => {
      el.classList.toggle('active', el.dataset.tag === tag);
    });

    filterResults.classList.remove('hidden');
    filterTitle.textContent = `"${tag}" のレポート`;

    const results = allReports.filter(r => r.tags.includes(tag));

    if (results.length === 0) {
      filterList.innerHTML = '<p class="empty">No reports found.</p>';
      return;
    }

    filterList.innerHTML = results.map(r => {
      const slug = r.id.split('/').slice(1).join('/');
      return `<a href="/${r.feature}/${slug}" class="result-item">
        <span class="result-dot" style="background: ${r.color}"></span>
        <div class="result-info">
          <span class="result-title">${r.title}</span>
          <span class="result-meta">${r.date} · ${r.feature}</span>
        </div>
      </a>`;
    }).join('');
  }

  function clearFilter() {
    activeTag = null;
    filterResults.classList.add('hidden');
    document.querySelectorAll('.clickable-tag').forEach(el => {
      el.classList.remove('active');
    });
  }

  document.querySelectorAll('.clickable-tag').forEach(el => {
    el.addEventListener('click', () => {
      const tag = el.dataset.tag;
      if (activeTag === tag) {
        clearFilter();
      } else {
        filterByTag(tag);
      }
    });
  });

  clearBtn.addEventListener('click', clearFilter);

  // URL パラメータ ?tag=xxx からの初期フィルタ
  const urlParams = new URLSearchParams(window.location.search);
  const initialTag = urlParams.get('tag');
  if (initialTag) {
    filterByTag(initialTag);
  }
</script>

<style>
  .tags-page { max-width: 100%; }
  h1 { font-size: 1.5rem; margin-bottom: 1.5rem; }
  h2 { font-size: 1.1rem; color: var(--color-text-muted); margin-bottom: 1rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }
  .tag-section { margin-bottom: 2rem; }
  .tag-list { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .tag-item {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.35rem 0.75rem; background: var(--color-surface);
    border: 1px solid var(--color-border); border-radius: 20px;
    font-size: 0.85rem; color: var(--color-text); cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }
  .tag-item:hover { border-color: var(--color-primary); }
  .tag-item.active { border-color: var(--color-primary); background: var(--color-primary); color: var(--color-bg); }
  .tag-item.active .count { background: rgba(255,255,255,0.2); color: var(--color-bg); }
  .tag-item .count { font-size: 0.7rem; color: var(--color-text-muted); background: var(--color-bg); padding: 0.1rem 0.4rem; border-radius: 10px; }
  .tag-cloud {
    display: flex; flex-wrap: wrap; gap: 0.5rem 1rem; align-items: baseline;
    padding: 1rem; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 8px;
  }
  .cloud-item { background: none; border: none; color: var(--color-text-muted); transition: color 0.2s; cursor: pointer; padding: 0.1rem 0.2rem; border-radius: 3px; }
  .cloud-item:hover { color: var(--color-primary); }
  .cloud-item.active { background: var(--color-primary); color: var(--color-bg); }
  .empty { color: var(--color-text-muted); font-style: italic; }
  .filter-results { margin-top: 2rem; padding: 1rem; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 8px; }
  .filter-results.hidden { display: none; }
  .filter-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem; }
  .filter-header h2 { margin-bottom: 0; }
  .clear-filter { background: none; border: 1px solid var(--color-border); border-radius: 4px; padding: 0.25rem 0.75rem; font-size: 0.8rem; color: var(--color-text-muted); cursor: pointer; transition: border-color 0.2s, color 0.2s; }
  .clear-filter:hover { border-color: var(--color-primary); color: var(--color-text); }
  .filter-list { display: flex; flex-direction: column; gap: 0.5rem; }
  :global(.result-item) { display: flex; align-items: center; gap: 0.6rem; padding: 0.5rem; border-radius: 6px; text-decoration: none; color: var(--color-text); transition: background 0.15s; }
  :global(.result-item:hover) { background: var(--color-bg); text-decoration: none; }
  :global(.result-dot) { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  :global(.result-info) { display: flex; flex-direction: column; }
  :global(.result-title) { font-size: 0.85rem; font-weight: 500; }
  :global(.result-meta) { font-size: 0.75rem; color: var(--color-text-muted); }
</style>
