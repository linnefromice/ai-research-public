---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { features, buildReportCardTitle, getFeatureLabel, getFeatureColor } from '../../features';
import { getUnpublishedIds, getAllReportTags, toD1Id } from '../../lib/d1-client';

// SSR に切替: スペース等を含むタグでの NoMatchingStaticPathFound を回避
export const prerender = false;

const { tag: encodedTag } = Astro.params;
const tag = decodeURIComponent(encodedTag ?? '');

const unpublished = await getUnpublishedIds();
const reportTags = await getAllReportTags();

interface TaggedReport {
  id: string;
  title: string;
  feature: string;
  featureLabel: string;
  featureColor: string;
  slug: string;
  date: string;
}

const matched: TaggedReport[] = [];
for (const f of features) {
  const reports = await getCollection(f.slug as any);
  for (const r of reports) {
    const id = toD1Id(f.slug, r.id);
    if (unpublished.has(id)) continue;
    const tags = reportTags.get(id) ?? [];
    if (tags.some(t => t.tag === tag)) {
      matched.push({
        id,
        title: buildReportCardTitle(f.slug, r.data.date),
        feature: f.slug,
        featureLabel: getFeatureLabel(f.slug),
        featureColor: getFeatureColor(f.slug),
        slug: r.id,
        date: r.data.date,
      });
    }
  }
}
matched.sort((a, b) => b.date.localeCompare(a.date));

const cutoff = new Date(Date.now() - 30 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);
const recent = matched.filter(r => r.date >= cutoff);
---

<BaseLayout title={`#${tag}`} activeFeature="_tags">
  <header style="margin-bottom: 1.5rem;">
    <nav style="font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 0.5rem;">
      <a href="/tags/" style="color: var(--color-primary);">← All tags</a>
    </nav>
    <h1 style="margin: 0;">#{tag}</h1>
    <p style="color: var(--color-text-muted); margin-top: 0.25rem;">
      {recent.length} reports in the last 30 days · {matched.length} total
    </p>
  </header>

  {recent.length === 0 ? (
    <p style="color: var(--color-text-muted);">No reports in the last 30 days.</p>
  ) : (
    <div style="display: grid; gap: 0.75rem;">
      {recent.map(r => (
        <a href={`/${r.feature}/${r.slug}/`} style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 8px; text-decoration: none; color: var(--color-text);">
          <span style={`width: 10px; height: 10px; border-radius: 50%; background: ${r.featureColor}; flex-shrink: 0;`}></span>
          <div style="flex: 1; min-width: 0;">
            <div style="font-weight: 500;">{r.title}</div>
            <div style="font-size: 0.8rem; color: var(--color-text-muted);">{r.featureLabel} · {r.date}</div>
          </div>
        </a>
      ))}
    </div>
  )}
</BaseLayout>
