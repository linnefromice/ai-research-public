---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { STALENESS_WARN_DAYS, ageInDays, isStale } from '../../config/deep-research';

export async function getStaticPaths() {
  const reports = await getCollection('deep-research');
  return reports.map(report => ({
    params: { topic: report.data.topic || report.id },
    props: { report },
  }));
}

const { report } = Astro.props;
const { Content, headings } = await render(report);

const updatedAt = report.data.updated_at;
const originalDate = report.data.original_date ?? report.data.date;
const refreshCount = report.data.refresh_count ?? 0;
const age = ageInDays(updatedAt, report.data.date);
const stale = isStale(updatedAt, report.data.date);

// TOC: exclude Sources, Metadata, and lower-level headings
const excludedSlugs = ['sources', 'metadata', 'sources-1'];
const tocHeadings = headings.filter(h =>
  h.depth === 2 && !excludedSlugs.includes(h.slug)
);

// Count sources
const sourcesMatch = (report.body ?? '').match(/Sources count: (\d+)/);
const sourcesCount = sourcesMatch ? sourcesMatch[1] : '0';

// Count phases
const phases = [];
if ((report.body ?? '').match(/Phases completed: ([\d,]+)/)) {
  const match = (report.body ?? '').match(/Phases completed: ([\d,]+)/);
  if (match) phases.push(...match[1].split(','));
}

// マークダウン生データ（Copy / Download 用）
const rawMarkdown = report.body ?? '';
const filename = `deep-research-${report.data.topic || report.id}.md`;
---

<BaseLayout title={report.data.title} activeFeature="deep-research">
  <div class="research-meta-bar">
    <span>Deep Research</span>
    {refreshCount > 0 && (
      <span class="version-badge">v{refreshCount + 1}</span>
    )}
    <span>|</span>
    <span>初版 {originalDate}</span>
    {refreshCount > 0 && (
      <>
        <span>|</span>
        <span>最終更新 {report.data.date} ({age}日前)</span>
      </>
    )}
    <span>|</span>
    <span>Engine: {report.data.engine}</span>
    <span>|</span>
    <span>{sourcesCount} sources</span>
    {phases.length > 0 && (
      <>
        <span>|</span>
        <span>Phases: {phases.join(', ')}</span>
      </>
    )}
  </div>

  {stale && age !== null && (
    <div class="staleness-warning" role="status">
      <strong>⚠ このレポートは {age} 日前の情報です</strong>
      <span>（しきい値 {STALENESS_WARN_DAYS} 日）。記載内容が最新状況と異なる可能性があります。</span>
    </div>
  )}

  {tocHeadings.length > 1 && (
    <details class="toc">
      <summary>目次</summary>
      <ol>
        {tocHeadings.map((h) => (
          <li><a href={`#${h.slug}`}>{h.text}</a></li>
        ))}
      </ol>
    </details>
  )}

  <div class="report-actions">
    <button class="action-btn" id="copy-md-btn" title="Copy as Markdown">
      <span class="action-icon">📋</span> Copy MD
    </button>
    <button class="action-btn" id="download-md-btn" title="Download as .md file">
      <span class="action-icon">⬇️</span> Download
    </button>
    <a class="action-btn" href={`${report.data.topic || report.id}.md`} title="View raw markdown (.md)">
      <span class="action-icon">📄</span> .md
    </a>
  </div>

  <script type="application/json" id="raw-markdown" set:html={JSON.stringify({ content: rawMarkdown, filename })} />

  <article class="report-content">
    <Content />
  </article>

  <nav class="back-nav">
    <a href="/deep-research/">&larr; Research 一覧に戻る</a>
  </nav>
</BaseLayout>

<script>
  // Desktop: open TOC, Mobile: closed
  const toc = document.querySelector('.toc');
  if (toc && window.innerWidth > 768) {
    toc.setAttribute('open', '');
  }

  // Copy / Download Markdown
  const rawData = JSON.parse(document.getElementById('raw-markdown')?.textContent || '{}');

  const copyBtn = document.getElementById('copy-md-btn');
  if (copyBtn && rawData.content) {
    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(rawData.content);
        const original = copyBtn.innerHTML;
        copyBtn.innerHTML = '<span class="action-icon">✅</span> Copied!';
        setTimeout(() => { copyBtn.innerHTML = original; }, 2000);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = rawData.content;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        const original = copyBtn.innerHTML;
        copyBtn.innerHTML = '<span class="action-icon">✅</span> Copied!';
        setTimeout(() => { copyBtn.innerHTML = original; }, 2000);
      }
    });
  }

  const downloadBtn = document.getElementById('download-md-btn');
  if (downloadBtn && rawData.content) {
    downloadBtn.addEventListener('click', () => {
      const blob = new Blob([rawData.content], { type: 'text/markdown;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = rawData.filename || 'deep-research.md';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    });
  }
</script>

<style>
  .research-meta-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    margin-bottom: 1rem;
    background: var(--color-surface);
    border-radius: 6px;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }
  .version-badge {
    background: var(--color-accent-deep-research);
    color: #fff;
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    font-weight: 600;
    font-size: 0.7rem;
  }
  .staleness-warning {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: baseline;
    padding: 0.75rem 1rem;
    margin-bottom: 1.5rem;
    background: var(--color-surface);
    border-left: 4px solid var(--color-warning, #f59e0b);
    border-radius: 6px;
    font-size: 0.85rem;
    color: var(--color-text);
  }
  .staleness-warning strong {
    color: var(--color-warning, #f59e0b);
  }
  .staleness-warning span {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }
  .report-actions {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
    justify-content: flex-end;
  }
  .action-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.4rem 0.8rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    color: var(--color-text-muted);
    font-size: 0.75rem;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }
  .action-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-text);
  }
  .action-icon {
    font-size: 0.85rem;
  }
  .toc {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    margin-bottom: 1.5rem;
  }
  .toc summary {
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    color: var(--color-text);
  }
  .toc ol {
    margin: 0.5rem 0 0;
    padding-left: 1.25rem;
    list-style: decimal;
  }
  .toc li { margin: 0.25rem 0; }
  .toc a {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .toc a:hover { color: var(--color-primary); }
  .back-nav {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }
  .back-nav a {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-decoration: none;
  }
  .back-nav a:hover { color: var(--color-primary); }

  @media (max-width: 768px) {
    .research-meta-bar { font-size: 0.7rem; gap: 0.35rem; }
  }
</style>
