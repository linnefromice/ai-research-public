---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import {
  REGION_META,
  features,
  getFeatureColor,
  getFeatureLabel,
  getFeatureRegion,
} from '../features';
import { getUnpublishedIds, toD1Id } from '../lib/d1-client';

const unpublished = await getUnpublishedIds();

const today = new Date().toISOString().slice(0, 10);
const yesterday = new Date(Date.now() - 86400000).toISOString().slice(0, 10);
const sevenDaysAgo = new Date(Date.now() - 7 * 86400000).toISOString().slice(0, 10);

const featureStats = [];
for (const f of features) {
  const allReports = await getCollection(f.slug as any);
  const reports = allReports.filter(r => !unpublished.has(toD1Id(f.slug, r.id)));
  const sorted = reports.sort((a, b) => b.data.date.localeCompare(a.data.date));

  const totalReports = sorted.length;
  const latestReport = sorted[0] || null;
  const latestDate = latestReport?.data.date || 'N/A';
  const engine = latestReport?.data.engine || 'N/A';

  let articleCount = 0;
  if (latestReport?.body) {
    articleCount = (latestReport.body.match(/^### /gm) || []).length;
  }

  const hasToday = sorted.some(r => r.data.date === today);
  const hasYesterday = sorted.some(r => r.data.date === yesterday);

  const recentCount = sorted.filter(r => r.data.date >= sevenDaysAgo).length;

  // Detect if this feature has session reports
  const hasSessions = sorted.some(r =>
    r.id.includes('-open') || r.id.includes('-mid') || r.id.includes('-close')
  );

  // Check today's session reports
  const sessionStatuses: Record<string, boolean> = {};
  if (hasSessions) {
    for (const s of ['open', 'mid', 'close']) {
      sessionStatuses[s] = sorted.some(r => r.data.date === today && r.data.session === s);
    }
  }

  const region = getFeatureRegion(f.slug);
  featureStats.push({
    slug: f.slug,
    label: getFeatureLabel(f.slug),
    color: getFeatureColor(f.slug),
    region,
    regionMeta: REGION_META[region],
    totalReports,
    latestDate,
    engine,
    articleCount,
    hasToday,
    hasYesterday,
    recentCount,
    hasSessions,
    sessionStatuses,
  });
}

const totalReportsAll = featureStats.reduce((sum, f) => sum + f.totalReports, 0);
const featuresWithToday = featureStats.filter(f => f.hasToday);
const featuresMissingToday = featureStats.filter(f => !f.hasToday);
---

<BaseLayout title="System Status" activeFeature="_status">
  <div class="status-page">
    <h1>System Status</h1>

    <section class="overview">
      <h2>Overview</h2>
      <div class="overview-grid">
        <div class="overview-item">
          <span class="overview-value">{totalReportsAll}</span>
          <span class="overview-label">Total Reports</span>
        </div>
        <div class="overview-item">
          <span class="overview-value">{featuresWithToday.length} / {featureStats.length}</span>
          <span class="overview-label">Today's Reports</span>
        </div>
      </div>
      {featuresMissingToday.length > 0 && (
        <div class="missing-today">
          <span class="missing-label">Missing today:</span>
          {featuresMissingToday.map((f, i) => (
            <span>
              <span class="missing-name" style={`color: ${f.color}`}>
                {f.label} <span class="missing-region">{f.regionMeta.flag}</span>
              </span>{i < featuresMissingToday.length - 1 ? ', ' : ''}
            </span>
          ))}
        </div>
      )}
    </section>

    <section class="features-section">
      <h2>Features</h2>
      <div class="features-grid">
        {featureStats.map((f) => {
          const statusClass = f.hasToday ? 'status-green' : f.hasYesterday ? 'status-yellow' : 'status-red';
          const statusTitle = f.hasToday ? 'Today\'s report exists' : f.hasYesterday ? 'Only yesterday\'s report' : 'No recent report';
          return (
            <div class="feature-card">
              <div class="card-header">
                <span class={`status-dot ${statusClass}`} title={statusTitle} />
                <span class="feature-name" style={`color: ${f.color}`}>{f.label}</span>
                <span class={`region-pill region-pill--${f.region}`} title={f.regionMeta.label}>
                  {f.regionMeta.flag} {f.regionMeta.short}
                </span>
              </div>
              <div class="card-body">
                <div class="stat-row">
                  <span class="stat-label">Latest</span>
                  <span class="stat-value">{f.latestDate}</span>
                </div>
                <div class="stat-row">
                  <span class="stat-label">Engine</span>
                  <span class="stat-value">{f.engine}</span>
                </div>
                <div class="stat-row">
                  <span class="stat-label">Articles</span>
                  <span class="stat-value">{f.articleCount}</span>
                </div>
                <div class="stat-row">
                  <span class="stat-label">Last 7 days</span>
                  <span class="stat-value">{f.recentCount} / 7</span>
                </div>
                <div class="stat-row">
                  <span class="stat-label">Total</span>
                  <span class="stat-value">{f.totalReports}</span>
                </div>
              </div>
              {f.hasSessions && (
                <div class="card-sessions">
                  <span class="stat-label">Sessions</span>
                  <span class="session-icons">
                    {Object.entries(f.sessionStatuses).map(([s, exists]) => (
                      <span class={`session-item ${exists ? 'session-ok' : 'session-missing'}`} title={s}>
                        {exists ? '\u2705' : '\u274C'} {s}
                      </span>
                    ))}
                  </span>
                </div>
              )}
              <div class="card-footer">
                <a href={`/${f.slug}/`}>View reports &rarr;</a>
              </div>
            </div>
          );
        })}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .status-page {
    max-width: 100%;
  }

  h1 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }

  h2 {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
  }

  /* Overview section */
  .overview {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25rem;
    margin-bottom: 2rem;
  }

  .overview-grid {
    display: flex;
    gap: 2rem;
    margin-bottom: 0.75rem;
  }

  .overview-item {
    display: flex;
    flex-direction: column;
  }

  .overview-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .overview-label {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .missing-today {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-border);
  }

  .missing-label {
    color: var(--color-danger);
    font-weight: 600;
    margin-right: 0.4rem;
  }

  .missing-name {
    font-weight: 500;
  }

  /* Features grid */
  .features-section {
    margin-bottom: 2rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  @media (max-width: 640px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Feature card */
  .feature-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .status-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .status-green {
    background: var(--color-success);
  }

  .status-yellow {
    background: var(--color-warning);
  }

  .status-red {
    background: var(--color-danger);
  }

  .feature-name {
    font-weight: 600;
    font-size: 0.95rem;
  }

  .region-pill {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    padding: 0.1rem 0.45rem;
    border-radius: 999px;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-muted);
  }
  .region-pill--global {
    background: color-mix(in srgb, var(--color-primary) 8%, var(--color-surface));
    border-color: color-mix(in srgb, var(--color-primary) 35%, var(--color-border));
    color: var(--color-primary);
  }

  .missing-region {
    font-size: 0.75em;
    vertical-align: baseline;
    margin-left: 0.15em;
  }

  .card-body {
    padding: 0.5rem 1rem;
  }

  .stat-row {
    display: flex;
    justify-content: space-between;
    padding: 0.3rem 0;
    font-size: 0.85rem;
  }

  .stat-row + .stat-row {
    border-top: 1px solid var(--color-border);
  }

  .stat-label {
    color: var(--color-text-muted);
  }

  .stat-value {
    color: var(--color-text);
    font-weight: 500;
  }

  .card-footer {
    padding: 0.5rem 1rem 0.75rem;
    border-top: 1px solid var(--color-border);
  }

  .card-footer a {
    font-size: 0.8rem;
    color: var(--color-primary);
    text-decoration: none;
  }

  .card-sessions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.4rem 1rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.8rem;
  }

  .session-icons {
    display: flex;
    gap: 0.5rem;
  }

  .session-item {
    font-size: 0.75rem;
    text-transform: uppercase;
  }

  .session-ok {
    color: var(--color-success);
  }

  .session-missing {
    color: var(--color-danger);
  }

  .card-footer a:hover {
    color: var(--color-primary-hover);
    text-decoration: underline;
  }
</style>
