---
/**
 * Trends page (SSG + client-side fetch).
 * SSR version returned "[object Object]" on Workers — see §16.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Trends" activeFeature="_trends">
  <h1>📈 Trend Keywords (Last 30 Days)</h1>
  <p style="color: var(--color-text-muted); margin-bottom: 1.5rem;">
    Top keywords appearing across published reports, with daily timelines.
  </p>

  <p id="trends-status" style="color: var(--color-text-muted);">Loading...</p>
  <div id="trends-list" style="display: grid; gap: 1rem;"></div>

  <script is:inline>
    (function () {
      var statusEl = document.getElementById('trends-status');
      var listEl = document.getElementById('trends-list');

      function escapeHtml(s) {
        if (s == null) return '';
        return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
      }

      function sparkline(data, w, h) {
        if (!data || !data.length) return '';
        w = w || 200; h = h || 30;
        var max = 1;
        for (var i = 0; i < data.length; i++) if (data[i].count > max) max = data[i].count;
        var step = w / Math.max(data.length - 1, 1);
        var pts = data.map(function (d, i) {
          return (i * step) + ',' + (h - (d.count / max) * h);
        }).join(' ');
        return '<svg width="' + w + '" height="' + h + '" viewBox="0 0 ' + w + ' ' + h + '">' +
               '<polyline fill="none" stroke="currentColor" stroke-width="2" points="' + pts + '" />' +
               '</svg>';
      }

      fetch('/api/trends?days=30&limit=8', { signal: AbortSignal.timeout(10000) })
        .then(function (r) { return r.ok ? r.json() : Promise.reject(r.status); })
        .then(function (data) {
          var tags = data.tags || [];
          if (!tags.length) {
            statusEl.textContent = 'No tag data yet.';
            return;
          }
          statusEl.style.display = 'none';
          listEl.innerHTML = tags.map(function (t) {
            var total = (t.data || []).reduce(function (s, d) { return s + d.count; }, 0);
            return (
              '<a href="/tags/' + encodeURIComponent(t.tag) + '/" ' +
              'style="display:flex;align-items:center;justify-content:space-between;padding:0.75rem 1rem;background:var(--color-surface);border:1px solid var(--color-border);border-radius:8px;text-decoration:none;color:var(--color-text);gap:1rem;">' +
              '<div style="flex:1;min-width:0;">' +
                '<div style="font-weight:600;">' + escapeHtml(t.tag) + '</div>' +
                '<div style="font-size:0.8rem;color:var(--color-text-muted);margin-top:0.25rem;">' + total + ' reports</div>' +
              '</div>' +
              '<div style="color:var(--color-text-muted);">' + sparkline(t.data) + '</div>' +
              '</a>'
            );
          }).join('');
        })
        .catch(function (e) {
          statusEl.textContent = 'Failed to load trends: ' + e;
          statusEl.style.color = 'var(--color-danger)';
        });
    })();
  </script>
</BaseLayout>
