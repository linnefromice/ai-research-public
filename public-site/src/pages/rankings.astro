---
/**
 * Rankings page (SSG + client-side fetch).
 * SSR version returned "[object Object]" on Workers — see §16.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Rankings" activeFeature="_rankings">
  <h1>📈 Top Reports (Last 30 Days)</h1>
  <p style="color: var(--color-text-muted); margin-bottom: 1.5rem;">
    Ranked by reaction count.
  </p>

  <p id="rankings-status" style="color: var(--color-text-muted);">Loading...</p>
  <div id="rankings-list" style="display: grid; gap: 0.75rem;"></div>

  <script is:inline>
    (function () {
      var statusEl = document.getElementById('rankings-status');
      var listEl = document.getElementById('rankings-list');

      function escapeHtml(s) {
        if (s == null) return '';
        return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
      }

      fetch('/api/rankings?days=30&limit=20', { signal: AbortSignal.timeout(8000) })
        .then(function (r) { return r.ok ? r.json() : Promise.reject(r.status); })
        .then(function (data) {
          var reports = data.reports || [];
          if (!reports.length) {
            statusEl.textContent = 'No reports yet.';
            return;
          }
          statusEl.style.display = 'none';
          listEl.innerHTML = reports.map(function (r, i) {
            var medal = i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : '#' + (i + 1);
            return (
              '<a href="/' + encodeURIComponent(r.feature) + '/' + encodeURIComponent(r.date) + '/" ' +
              'style="display:flex;align-items:center;gap:0.75rem;padding:0.75rem 1rem;background:var(--color-surface);border:1px solid var(--color-border);border-radius:8px;text-decoration:none;color:var(--color-text);">' +
              '<span style="font-size:1.2rem;min-width:2.2rem;">' + medal + '</span>' +
              '<div style="flex:1;">' +
                '<div style="font-weight:600;">' + escapeHtml(r.title) + '</div>' +
                '<div style="font-size:0.8rem;color:var(--color-text-muted);margin-top:0.25rem;">' +
                  escapeHtml(r.feature) + ' · ' + escapeHtml(r.date) + '</div>' +
              '</div>' +
              '<span style="font-size:0.85rem;color:var(--color-text-muted);">👍 ' + r.reaction_count + '</span>' +
              '</a>'
            );
          }).join('');
        })
        .catch(function (e) {
          statusEl.textContent = 'Failed to load rankings: ' + e;
          statusEl.style.color = 'var(--color-danger)';
        });
    })();
  </script>
</BaseLayout>
