---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCfEnv } from '../lib/api-helpers';
export const prerender = false;

interface TopReport {
  id: string;
  feature: string;
  date: string;
  title: string;
  reaction_count: number;
}

const cfEnv = getCfEnv();
const db = cfEnv?.DB;

let topReports: TopReport[] = [];
let errorMsg = '';
if (db) {
  try {
    const since = new Date(Date.now() - 30 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);
    const result = await db.prepare(`
      SELECT r.id, r.feature, r.date,
             COALESCE(r.title, r.feature || ' ' || r.date) AS title,
             COUNT(rx.id) AS reaction_count
      FROM reports r
      LEFT JOIN reactions rx ON rx.report_id = r.id
      WHERE r.published = 1 AND r.date >= ?
      GROUP BY r.id
      ORDER BY reaction_count DESC, r.date DESC
      LIMIT 20
    `).bind(since).all<TopReport>();
    topReports = result.results ?? [];
  } catch (e) {
    errorMsg = e instanceof Error ? e.message : 'unknown error';
    console.warn('[rankings] query failed:', errorMsg);
  }
}
---

<BaseLayout title="Rankings" activeFeature="_rankings">
  <h1>📈 Monthly Rankings</h1>
  <p style="color: var(--color-text-muted); margin-bottom: 1.5rem;">
    Top engaged reports in the last 30 days
  </p>

  {topReports.length === 0 ? (
    <p style="color: var(--color-text-muted);">No data available (D1 not configured or no reactions yet).</p>
  ) : (
    <ol style="list-style: none; padding: 0; display: grid; gap: 0.5rem;">
      {topReports.map((r, i) => (
        <li style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 8px;">
          <span style="font-weight: 700; min-width: 2em; color: var(--color-text-muted);">{i + 1}</span>
          <a href={`/${r.feature}/${r.date}/`} style="flex: 1; text-decoration: none; color: var(--color-text);">
            <div style="font-weight: 500;">{r.title}</div>
            <div style="font-size: 0.8rem; color: var(--color-text-muted);">{r.feature} · {r.date}</div>
          </a>
          <span style="color: var(--color-accent-tech); font-weight: 600;">
            {r.reaction_count} 👍
          </span>
        </li>
      ))}
    </ol>
  )}
</BaseLayout>
