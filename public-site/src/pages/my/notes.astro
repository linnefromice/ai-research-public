---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { features } from '../../features';
import { MyNotesList } from '../../components/MyNotesList';

// features 定義を React に渡すため、var() を解決できる形で整形
const featureInfos = features.map((f) => ({
  slug: f.slug,
  label: f.label,
  color: f.color,
}));
---

<BaseLayout title="My Notes" activeFeature="_my_notes">
  <header class="page-header">
    <h1>📝 My Notes</h1>
    <p class="muted">自分が書いた個人メモの一覧。ログインが必要です。</p>
  </header>

  <MyNotesList client:load features={featureInfos} />
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 1.5rem;
  }
  .page-header h1 {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }
  .muted {
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }
</style>
