---
/**
 * Search page (SSG + client-side fetch).
 *
 * The previous SSR implementation returned "[object Object]" 15 bytes on
 * Cloudflare Workers (see .claude/rules/cloudflare-astro-patterns.md §16).
 * Pattern: render an empty shell, fetch /api/search?q=... on the client.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Search" activeFeature="_search">
  <h1>🔍 Search</h1>
  <form id="search-form" method="get" style="margin: 1rem 0;">
    <input type="search" name="q" id="search-input" placeholder="Search reports..." autofocus
      style="width: 100%; padding: 0.75rem 1rem; font-size: 1rem; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 8px; color: var(--color-text);" />
  </form>

  <p id="search-error" style="color: var(--color-danger); display: none;"></p>
  <p id="search-status" style="color: var(--color-text-muted);"></p>
  <div id="search-results" style="display: grid; gap: 0.75rem;"></div>

  <script is:inline>
    (function () {
      var input = document.getElementById('search-input');
      var form = document.getElementById('search-form');
      var resultsDiv = document.getElementById('search-results');
      var statusEl = document.getElementById('search-status');
      var errorEl = document.getElementById('search-error');

      function escapeHtml(s) {
        if (s == null) return '';
        return String(s)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      function stripMarkdown(s) {
        if (!s) return '';
        return String(s)
          .replace(/^---[\s\S]*?---\s*/m, '')
          .replace(/!\[[^\]]*\]\([^)]+\)/g, '')
          .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
          .replace(/`([^`]+)`/g, '$1')
          .replace(/\*\*([^*]+)\*\*/g, '$1')
          .replace(/__([^_]+)__/g, '$1')
          .replace(/#{1,6}\s+/gm, '')
          .replace(/^>\s?/gm, '')
          .replace(/^\s*[-*+]\s+/gm, '')
          .replace(/^\s*\d+\.\s+/gm, '')
          .replace(/\|[^\n]+\|/g, '')
          .replace(/\n+/g, ' ')
          .replace(/\s{2,}/g, ' ')
          .trim();
      }

      function renderTags(tagsStr) {
        if (!tagsStr) return '';
        var tags = tagsStr.split(',').filter(Boolean);
        if (!tags.length) return '';
        var shown = tags.slice(0, 5);
        var more = tags.length - shown.length;
        var tagStyle = 'font-size:0.65rem;padding:0.1rem 0.35rem;background:var(--color-border);border-radius:3px;color:var(--color-text-muted);';
        var html = '<div style="display:flex;flex-wrap:wrap;gap:0.25rem;margin-top:0.5rem;">';
        html += shown.map(function (t) {
          return '<span style="' + tagStyle + '">' + escapeHtml(t) + '</span>';
        }).join('');
        if (more > 0) {
          html += '<span style="font-size:0.65rem;color:var(--color-text-muted);padding:0.1rem 0.15rem;">+' + more + '</span>';
        }
        html += '</div>';
        return html;
      }

      function renderExcerpt(excerptStr) {
        var text = stripMarkdown(excerptStr);
        if (!text) return '';
        if (text.length > 160) text = text.slice(0, 160) + '…';
        return '<div style="margin-top:0.4rem;font-size:0.8rem;color:var(--color-text-muted);line-height:1.5;">' + escapeHtml(text) + '</div>';
      }

      function render(results, q) {
        resultsDiv.innerHTML = '';
        errorEl.style.display = 'none';
        if (q.length < 2) { statusEl.textContent = ''; return; }
        if (!results.length) { statusEl.textContent = 'No results for "' + q + '"'; return; }
        statusEl.textContent = results.length + ' results';
        resultsDiv.innerHTML = results.map(function (r) {
          var title = r.title || (r.feature + ' ' + r.date);
          var href = r.feature === 'deep-research'
            ? '/deep-research/' + encodeURIComponent(r.id.replace('deep-research/', '')) + '/'
            : '/' + encodeURIComponent(r.feature) + '/' + encodeURIComponent(r.date) + '/';
          return (
            '<a href="' + href + '" ' +
            'style="display:block;padding:0.75rem 1rem;background:var(--color-surface);border:1px solid var(--color-border);border-radius:8px;text-decoration:none;color:var(--color-text);">' +
            '<div style="font-weight:600;">' + escapeHtml(title) + '</div>' +
            '<div style="font-size:0.8rem;color:var(--color-text-muted);margin-top:0.25rem;">' +
              escapeHtml(r.feature) + ' · ' + escapeHtml(r.date) + '</div>' +
            renderExcerpt(r.excerpt) +
            renderTags(r.tags) +
            '</a>'
          );
        }).join('');
      }

      function search(q) {
        if (q.length < 2) { render([], q); return; }
        statusEl.textContent = 'Searching...';
        fetch('/api/search?q=' + encodeURIComponent(q), { signal: AbortSignal.timeout(8000) })
          .then(function (r) { return r.ok ? r.json() : Promise.reject(r.status); })
          .then(function (data) { render(data.results || [], q); })
          .catch(function (e) {
            errorEl.textContent = 'Search failed: ' + e;
            errorEl.style.display = '';
            statusEl.textContent = '';
          });
      }

      var initialQ = new URL(location.href).searchParams.get('q') || '';
      input.value = initialQ;
      if (initialQ) search(initialQ.trim());

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var q = input.value.trim();
        var url = new URL(location.href);
        if (q) url.searchParams.set('q', q); else url.searchParams.delete('q');
        history.replaceState(null, '', url.toString());
        search(q);
      });
    })();
  </script>
</BaseLayout>
