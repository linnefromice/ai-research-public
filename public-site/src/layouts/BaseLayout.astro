---
import Navigation from '../components/Navigation.astro';
import '../styles/global.css';

interface Props {
  title: string;
  activeFeature?: string;
}

const { title, activeFeature } = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | OpenClaw Reports</title>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📊</text></svg>" />
  <link rel="alternate" type="application/rss+xml" title="OpenClaw Reports RSS" href="/feed/index.xml" />
  <link rel="manifest" href="/manifest.webmanifest" />
  <script is:inline>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      });
    }
  </script>
  <script is:inline>
    (function() {
      var theme = localStorage.getItem('theme');
      if (theme === 'light') document.documentElement.dataset.theme = 'light';
    })();
  </script>
</head>
<body>
  <Navigation activeFeature={activeFeature} />
  <main>
    <slot />
  </main>
  <footer>
    <p>Generated by OpenClaw Automation</p>
  </footer>
  <div class="footer-spacer"></div>
  <script is:inline>
    // Update read/bookmark badges on report cards
    (function() {
      try {
        var bookmarks = JSON.parse(localStorage.getItem('openclaw_bookmarks') || '[]');
        var readReports = JSON.parse(localStorage.getItem('openclaw_read') || '[]');
        document.querySelectorAll('[data-card-id]').forEach(function(card) {
          var id = card.getAttribute('data-card-id');
          if (readReports.includes(id)) {
            var badge = card.querySelector('.read-badge');
            if (badge) badge.style.display = '';
          }
          if (bookmarks.includes(id)) {
            var bmark = card.querySelector('.bookmark-badge');
            if (bmark) bmark.style.display = '';
          }
        });
      } catch(e) {}
    })();
  </script>
</body>
</html>

<style>
  footer {
    max-width: var(--max-width);
    margin: 2rem auto;
    padding: 1rem;
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.8rem;
    border-top: 1px solid var(--color-border);
  }
  @media (min-width: 769px) {
    footer { margin-left: var(--sidebar-width); }
  }
  /* Mobile bottom bar spacer */
  .footer-spacer { display: none; }
  @media (max-width: 768px) {
    .footer-spacer { display: block; height: 60px; }
  }
</style>
